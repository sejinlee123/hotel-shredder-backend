# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/your_database
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# JPA (optional; defaults: update, true)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT signing secret (use a long random string)
JWT_SECRET=your_jwt_secret_at_least_32_chars_long

# Mail (e.g. Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Optional: port when not set by host (e.g. Railway sets PORT)
# PORT=9090
